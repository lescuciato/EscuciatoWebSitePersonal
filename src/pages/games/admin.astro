---
/**
 * Games admin — manage game entries (protected route).
 * CRUD for games with inline form.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { gamesDb } from '../../lib/db';

const games = gamesDb.getAll();

const statusOptions = [
  { value: 'playing',  label: 'Playing Now' },
  { value: 'finished', label: 'Finished' },
  { value: 'queued',   label: 'In Queue' },
  { value: 'paused',   label: 'Paused' },
];
---

<BaseLayout title="Games Admin" description="Manage game entries">
  <div class="admin-page section">
    <div class="container">
      <div class="admin-header">
        <div>
          <h1 class="section-title">Games <span>Admin</span></h1>
          <p class="admin-subtitle">{games.length} game{games.length !== 1 ? 's' : ''} in collection</p>
        </div>
        <div class="admin-actions">
          <button class="btn btn-primary" id="add-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Add Game
          </button>
          <a href="/api/auth/logout" class="btn btn-ghost">Log out</a>
        </div>
      </div>

      <!-- Add/Edit form (hidden by default) -->
      <div id="game-form-section" class="game-form-section" hidden>
        <h2 class="form-section-title">Add New Game</h2>
        <form id="game-form" class="game-form">
          <input type="hidden" id="game-id" name="id" value="" />

          <div class="form-row">
            <div class="form-group">
              <label for="g-title" class="form-label">Title *</label>
              <input type="text" id="g-title" name="title" class="form-input" required placeholder="Game title" />
            </div>
            <div class="form-group">
              <label for="g-platform" class="form-label">Platform</label>
              <input type="text" id="g-platform" name="platform" class="form-input" placeholder="PC, PS5, Xbox, Mobile..." />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="g-status" class="form-label">Status</label>
              <select id="g-status" name="status" class="form-input">
                {statusOptions.map(({ value, label }) => (
                  <option value={value}>{label}</option>
                ))}
              </select>
            </div>
            <div class="form-group">
              <label for="g-rating" class="form-label">Rating (1–5)</label>
              <input type="number" id="g-rating" name="rating" class="form-input" min="0" max="5" value="0" />
            </div>
          </div>

          <div class="form-group">
            <label for="g-cover" class="form-label">Cover Image URL</label>
            <input type="url" id="g-cover" name="cover_url" class="form-input" placeholder="https://..." />
          </div>

          <div class="form-group">
            <label for="g-review" class="form-label">Review / Notes</label>
            <textarea id="g-review" name="review" class="form-textarea" rows="3" placeholder="Your thoughts on this game..."></textarea>
          </div>

          <div class="form-actions">
            <button type="button" class="btn btn-ghost" id="cancel-btn">Cancel</button>
            <button type="submit" class="btn btn-primary" id="save-btn">Save Game</button>
          </div>
        </form>
      </div>

      <!-- Games list -->
      {games.length === 0 ? (
        <div class="admin-empty">
          <p>No games yet. Click "Add Game" to start your collection.</p>
        </div>
      ) : (
        <div class="games-list">
          {games.map((game) => (
            <div class="game-row">
              <div class="game-row-cover">
                {game.cover_url ? (
                  <img src={game.cover_url} alt={game.title} width="60" height="34" loading="lazy" />
                ) : (
                  <div class="cover-placeholder" aria-hidden="true">🎮</div>
                )}
              </div>
              <div class="game-row-info">
                <span class="game-row-title">{game.title}</span>
                <span class="game-row-meta">
                  {game.platform ?? '—'} · {game.status} · {'★'.repeat(game.rating)}{'☆'.repeat(5 - game.rating)}
                </span>
              </div>
              <div class="game-row-actions">
                <button
                  class="btn btn-ghost btn-sm"
                  data-action="edit"
                  data-game={JSON.stringify(game)}
                >
                  Edit
                </button>
                <button
                  class="btn btn-danger btn-sm"
                  data-action="delete"
                  data-game-id={game.id}
                >
                  Delete
                </button>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<script>
  const addBtn = document.getElementById('add-btn') as HTMLButtonElement;
  const cancelBtn = document.getElementById('cancel-btn') as HTMLButtonElement;
  const formSection = document.getElementById('game-form-section') as HTMLDivElement;
  const form = document.getElementById('game-form') as HTMLFormElement;
  const formTitle = document.querySelector('.form-section-title') as HTMLHeadingElement;
  const gameIdInput = document.getElementById('game-id') as HTMLInputElement;
  const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;

  function showForm(editData?: Record<string, unknown>) {
    formSection.hidden = false;
    formSection.scrollIntoView({ behavior: 'smooth', block: 'start' });

    if (editData) {
      formTitle.textContent = 'Edit Game';
      saveBtn.textContent = 'Update Game';
      gameIdInput.value = String(editData.id);
      (document.getElementById('g-title') as HTMLInputElement).value = String(editData.title ?? '');
      (document.getElementById('g-platform') as HTMLInputElement).value = String(editData.platform ?? '');
      (document.getElementById('g-status') as HTMLSelectElement).value = String(editData.status ?? 'queued');
      (document.getElementById('g-rating') as HTMLInputElement).value = String(editData.rating ?? 0);
      (document.getElementById('g-cover') as HTMLInputElement).value = String(editData.cover_url ?? '');
      (document.getElementById('g-review') as HTMLTextAreaElement).value = String(editData.review ?? '');
    } else {
      formTitle.textContent = 'Add New Game';
      saveBtn.textContent = 'Save Game';
      form.reset();
      gameIdInput.value = '';
    }
  }

  addBtn.addEventListener('click', () => showForm());
  cancelBtn.addEventListener('click', () => { formSection.hidden = true; });

  // Edit / delete buttons on list rows
  document.querySelectorAll('[data-action]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLButtonElement;
      const action = el.dataset.action;

      if (action === 'edit') {
        const game = JSON.parse(el.dataset.game ?? '{}');
        showForm(game);
      }

      if (action === 'delete') {
        if (!confirm('Remove this game from your collection?')) return;
        const gameId = el.dataset.gameId;
        const res = await fetch(`/api/games/${gameId}`, { method: 'DELETE' });
        if (res.ok) window.location.reload();
        else alert('Failed to delete game.');
      }
    });
  });

  // Form submit
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const id = gameIdInput.value;

    const payload = {
      title: formData.get('title') as string,
      platform: formData.get('platform') as string,
      status: formData.get('status') as string,
      rating: Number(formData.get('rating')),
      review: formData.get('review') as string,
      cover_url: formData.get('cover_url') as string,
    };

    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';

    try {
      const url = id ? `/api/games/${id}` : '/api/games';
      const method = id ? 'PUT' : 'POST';
      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (res.ok) {
        window.location.reload();
      } else {
        const err = await res.json();
        alert(`Error: ${err.message ?? 'Failed to save game.'}`);
        saveBtn.disabled = false;
        saveBtn.textContent = id ? 'Update Game' : 'Save Game';
      }
    } catch {
      alert('Network error. Please try again.');
      saveBtn.disabled = false;
    }
  });
</script>

<style>
  .admin-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  .admin-subtitle {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-top: 4px;
  }

  .admin-actions {
    display: flex;
    gap: var(--space-2);
  }

  .admin-empty {
    text-align: center;
    padding: var(--space-8);
    color: var(--color-text-muted);
  }

  /* ─── Form section ─── */
  .game-form-section {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .form-section-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: var(--space-4);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .form-row {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-3);
    }
  }

  .form-actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-2);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  /* ─── Games list ─── */
  .games-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .game-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 12px var(--space-3);
    flex-wrap: wrap;
    transition: border-color var(--transition-fast);
  }

  .game-row:hover {
    border-color: rgba(99, 102, 241, 0.3);
  }

  .game-row-cover {
    width: 60px;
    height: 34px;
    border-radius: 4px;
    overflow: hidden;
    background: #0a0a18;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .game-row-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cover-placeholder {
    font-size: 1.2rem;
  }

  .game-row-info {
    flex: 1;
    min-width: 0;
  }

  .game-row-title {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .game-row-meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-family: 'JetBrains Mono', monospace;
  }

  .game-row-actions {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .btn-sm {
    padding: 5px 12px;
    font-size: 0.78rem;
  }
</style>
