---
/**
 * Home page — personal presentation for Leonardo Escuciato.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import Hobbies from '../components/home/Hobbies.astro';
import { getLang, useTranslations } from '../i18n/index';

const lang = getLang(Astro.cookies);
const t = useTranslations(lang);
---

<BaseLayout
  title="Home"
  description="Leonardo Escuciato — Campinas, São Paulo, Brasil. Apaixonado por tecnologia e lifestyle."
  lang={lang}
>
  <Hero t={t} />
  <Hobbies t={t} />
</BaseLayout>
