---
/**
 * Sobre o Site — documentação pública da arquitetura, stack e guia de replicação.
 * Rota: /sobre-o-site
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLang, useTranslations } from '../i18n/index';

const lang = getLang(Astro.cookies);
const t = useTranslations(lang);
---

<BaseLayout
  title={t.sobreSite.pageTitle}
  description={t.sobreSite.metaDescription}
  lang={lang}
>
  <div class="docs-page">

    <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
    <div class="docs-hero">
      <div class="container">
        <div class="docs-hero-content fade-in">
          <span class="docs-badge">{t.sobreSite.heroBadge}</span>
          <h1>{t.sobreSite.heroTitle}</h1>
          <p class="docs-hero-desc">
            {t.sobreSite.heroDesc}
          </p>
          <p class="docs-collab-note">
            {t.sobreSite.heroCollabNote} <a href="https://claude.ai" target="_blank" rel="noopener">Claude (Anthropic)</a>
            {t.sobreSite.heroCollabUsing} <a href="https://claude.ai/code" target="_blank" rel="noopener">Claude Code</a> {t.sobreSite.heroCollabSuffix}
          </p>
        </div>
      </div>
    </div>

    <!-- ─── Layout: sidebar + content ────────────────────────────────────── -->
    <div class="container docs-layout">

      <!-- Sidebar (ancora nav) -->
      <aside class="docs-sidebar" aria-label={t.sobreSite.sidebarAriaLabel}>
        <nav class="sidebar-nav">
          <p class="sidebar-label">{t.sobreSite.sidebarLabel}</p>
          <a href="#visao-geral" class="sidebar-link">{t.sobreSite.nav.overview}</a>
          <a href="#stack" class="sidebar-link">{t.sobreSite.nav.stack}</a>
          <a href="#arquitetura" class="sidebar-link">{t.sobreSite.nav.architecture}</a>
          <a href="#local" class="sidebar-link">{t.sobreSite.nav.local}</a>
          <a href="#deploy" class="sidebar-link">{t.sobreSite.nav.deploy}</a>
          <a href="#agentes" class="sidebar-link">{t.sobreSite.nav.agents}</a>
          <a href="#guia" class="sidebar-link">{t.sobreSite.nav.guide}</a>
          <a href="#i18n" class="sidebar-link">{t.sobreSite.nav.i18n}</a>
          <a href="#usando-ai" class="sidebar-link">{t.sobreSite.nav.ai}</a>
        </nav>
      </aside>

      <!-- Main content -->
      <main class="docs-content" id="main-content">

        <!-- ─── 1. Visão Geral ─────────────────────────────────────────── -->
        <section id="visao-geral" class="docs-section fade-in">
          <div class="section-number">01</div>
          <h2>{t.sobreSite.sections.visaoGeral.title}</h2>
          <p set:html={t.sobreSite.sections.visaoGeral.desc1} />
          <p set:html={t.sobreSite.sections.visaoGeral.desc2} />
          <p set:html={t.sobreSite.sections.visaoGeral.desc3} />
          <div class="feature-grid">
            <div class="feature-card">
              <span class="feature-icon">&#9998;</span>
              <strong>{t.sobreSite.sections.visaoGeral.featureBlog}</strong>
              <span>{t.sobreSite.sections.visaoGeral.featureBlogDesc}</span>
            </div>
            <div class="feature-card">
              <span class="feature-icon">&#9654;</span>
              <strong>{t.sobreSite.sections.visaoGeral.featureGames}</strong>
              <span>{t.sobreSite.sections.visaoGeral.featureGamesDesc}</span>
            </div>
            <div class="feature-card">
              <span class="feature-icon">&#8634;</span>
              <strong>{t.sobreSite.sections.visaoGeral.featureDeploy}</strong>
              <span>{t.sobreSite.sections.visaoGeral.featureDeployDesc}</span>
            </div>
            <div class="feature-card">
              <span class="feature-icon">&#128274;</span>
              <strong>{t.sobreSite.sections.visaoGeral.featureTls}</strong>
              <span>{t.sobreSite.sections.visaoGeral.featureTlsDesc}</span>
            </div>
          </div>
        </section>

        <!-- ─── 2. Stack ───────────────────────────────────────────────── -->
        <section id="stack" class="docs-section fade-in">
          <div class="section-number">02</div>
          <h2>{t.sobreSite.sections.stack.title}</h2>

          <h3>{t.sobreSite.sections.stack.subtitleApp}</h3>
          <div class="tech-table-wrapper">
            <table class="tech-table">
              <thead>
                <tr>
                  <th>{t.sobreSite.sections.stack.colTech}</th>
                  <th>{t.sobreSite.sections.stack.colVersion}</th>
                  <th>{t.sobreSite.sections.stack.colRole}</th>
                </tr>
              </thead>
              <tbody>
                <tr class="tech-row">
                  <td><span class="tech-name">Astro</span></td>
                  <td class="tech-version">4.x</td>
                  <td>
                    <span class="tech-func">Framework SSR — server-side rendering</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="3" class="why-content">
                    <div class="why-inner">Escolhido por ser o framework mais eficiente para sites com conteúdo misto — páginas estáticas e dinâmicas coexistindo. O modelo de "ilhas" permite hidratar apenas os componentes interativos, reduzindo o JavaScript enviado ao browser.</div>
                  </td>
                </tr>
                <tr class="tech-row">
                  <td><span class="tech-name">@astrojs/node</span></td>
                  <td class="tech-version">—</td>
                  <td>
                    <span class="tech-func">Adapter Node.js para modo SSR</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="3" class="why-content">
                    <div class="why-inner">Necessário para rodar o Astro em modo servidor (SSR). Transforma o build em um servidor Node.js standalone que pode ser gerenciado pelo PM2.</div>
                  </td>
                </tr>
                <tr class="tech-row">
                  <td><span class="tech-name">React</span></td>
                  <td class="tech-version">18.x</td>
                  <td>
                    <span class="tech-func">Componentes interativos (ilhas Astro)</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="3" class="why-content">
                    <div class="why-inner">Usado apenas onde há interatividade real — o editor TipTap do blog. O Astro carrega o React apenas nessas "ilhas", sem impacto no restante das páginas.</div>
                  </td>
                </tr>
                <tr class="tech-row">
                  <td><span class="tech-name">Tailwind CSS</span></td>
                  <td class="tech-version">3.x</td>
                  <td>
                    <span class="tech-func">Estilização utilitária</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="3" class="why-content">
                    <div class="why-inner">Permite estilização rápida e consistente sem sair do HTML. Elimina o problema de CSS crescendo de forma descontrolada, pois as classes utilitárias são purged no build final.</div>
                  </td>
                </tr>
                <tr class="tech-row">
                  <td><span class="tech-name">TipTap</span></td>
                  <td class="tech-version">2.x</td>
                  <td>
                    <span class="tech-func">Editor de texto rico para o Blog</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="3" class="why-content">
                    <div class="why-inner">Editor rico baseado em ProseMirror com API moderna para React. Escolhido pela flexibilidade de extensões, boa documentação e capacidade de exportar HTML limpo para salvar no banco.</div>
                  </td>
                </tr>
                <tr class="tech-row">
                  <td><span class="tech-name">better-sqlite3</span></td>
                  <td class="tech-version">—</td>
                  <td>
                    <span class="tech-func">Banco de dados SQLite local</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="3" class="why-content">
                    <div class="why-inner">SQLite síncrono e sem servidor separado — perfeito para um blog pessoal. Zero configuração de infraestrutura, o banco é um único arquivo no servidor.</div>
                  </td>
                </tr>
                <tr class="tech-row">
                  <td><span class="tech-name">jose</span></td>
                  <td class="tech-version">—</td>
                  <td>
                    <span class="tech-func">JWT para autenticação</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="3" class="why-content">
                    <div class="why-inner">Biblioteca leve e moderna para JWT que funciona tanto no Node.js quanto em ambientes edge. Usada para gerar e verificar tokens de sessão da área admin.</div>
                  </td>
                </tr>
                <tr class="tech-row">
                  <td><span class="tech-name">TypeScript</span></td>
                  <td class="tech-version">—</td>
                  <td>
                    <span class="tech-func">Tipagem estática</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="3" class="why-content">
                    <div class="why-inner">Adiciona tipagem estática ao JavaScript, prevenindo erros em tempo de desenvolvimento. No Astro, é suportado nativamente sem configuração extra.</div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <h3>{t.sobreSite.sections.stack.subtitleInfra}</h3>
          <div class="tech-table-wrapper">
            <table class="tech-table">
              <thead>
                <tr>
                  <th>{t.sobreSite.sections.stack.colTech}</th>
                  <th>{t.sobreSite.sections.stack.colVersion}</th>
                  <th>{t.sobreSite.sections.stack.colRole}</th>
                </tr>
              </thead>
              <tbody>
                <tr class="tech-row">
                  <td><span class="tech-name">Ubuntu</span></td>
                  <td class="tech-version">24.04 LTS</td>
                  <td>
                    <span class="tech-func">Sistema operacional do VPS</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="3" class="why-content">
                    <div class="why-inner">Sistema operacional estável e amplamente suportado para servidores. A versão LTS garante suporte de segurança por 5 anos.</div>
                  </td>
                </tr>
                <tr class="tech-row">
                  <td><span class="tech-name">Docker</span></td>
                  <td class="tech-version">29.x</td>
                  <td>
                    <span class="tech-func">Orquestração de containers</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="3" class="why-content">
                    <div class="why-inner">Permite rodar o Nginx em um container isolado sem conflitar com outros serviços já existentes no servidor (n8n, Traefik). Facilita atualizações e rollback.</div>
                  </td>
                </tr>
                <tr class="tech-row">
                  <td><span class="tech-name">Traefik</span></td>
                  <td class="tech-version">v3.6</td>
                  <td>
                    <span class="tech-func">Reverse proxy + TLS automático (Let's Encrypt)</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="3" class="why-content">
                    <div class="why-inner">Já estava no servidor para gerenciar o n8n. Detecta containers Docker automaticamente via labels e provisiona certificados TLS pelo Let's Encrypt sem configuração manual.</div>
                  </td>
                </tr>
                <tr class="tech-row">
                  <td><span class="tech-name">Nginx</span></td>
                  <td class="tech-version">alpine</td>
                  <td>
                    <span class="tech-func">Container Docker — proxy para o Node.js</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="3" class="why-content">
                    <div class="why-inner">Atua como proxy reverso dentro do Docker, recebendo as requisições do Traefik e encaminhando para o processo Node.js na porta 4321 do host via <code>host.docker.internal</code>.</div>
                  </td>
                </tr>
                <tr class="tech-row">
                  <td><span class="tech-name">PM2</span></td>
                  <td class="tech-version">6.x</td>
                  <td>
                    <span class="tech-func">Gerenciador de processos Node.js</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="3" class="why-content">
                    <div class="why-inner">Mantém o processo Node.js do Astro sempre rodando. Se o processo cair, o PM2 reinicia automaticamente. Também persiste os processos entre reboots do servidor.</div>
                  </td>
                </tr>
                <tr class="tech-row">
                  <td><span class="tech-name">Node.js</span></td>
                  <td class="tech-version">v24.x</td>
                  <td>
                    <span class="tech-func">Runtime (via nvm)</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="3" class="why-content">
                    <div class="why-inner">Runtime necessário para executar o servidor Astro SSR e rodar o build. Instalado via nvm para facilitar troca de versões sem conflitos com o sistema operacional.</div>
                  </td>
                </tr>
                <tr class="tech-row">
                  <td><span class="tech-name">Git</span></td>
                  <td class="tech-version">2.x</td>
                  <td>
                    <span class="tech-func">Controle de versão + trigger de deploy</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="3" class="why-content">
                    <div class="why-inner">Além do controle de versão, serve como mecanismo de deploy. O hook <code>post-receive</code> no repositório bare dispara o build automaticamente a cada <code>git push</code>.</div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <h3>{t.sobreSite.sections.stack.subtitleDev}</h3>
          <div class="tech-table-wrapper">
            <table class="tech-table">
              <thead>
                <tr>
                  <th>{t.sobreSite.sections.stack.colTool}</th>
                  <th>{t.sobreSite.sections.stack.colRole}</th>
                </tr>
              </thead>
              <tbody>
                <tr class="tech-row">
                  <td><span class="tech-name">Claude Code</span></td>
                  <td>
                    <span class="tech-func">CLI de desenvolvimento assistido por IA (Anthropic)</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="2" class="why-content">
                    <div class="why-inner">CLI da Anthropic que permite ao Claude interagir diretamente com o sistema de arquivos, terminal e Git. Todo o desenvolvimento deste site foi feito através de conversas em linguagem natural com agentes especializados.</div>
                  </td>
                </tr>
                <tr class="tech-row">
                  <td><span class="tech-name">VS Code</span></td>
                  <td>
                    <span class="tech-func">Editor de código</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="2" class="why-content">
                    <div class="why-inner">Editor principal para revisão do código gerado pelos agentes, com suporte nativo a TypeScript, Astro e integração com o terminal onde o Claude Code roda.</div>
                  </td>
                </tr>
                <tr class="tech-row">
                  <td><span class="tech-name">nvm</span></td>
                  <td>
                    <span class="tech-func">Gerenciador de versões do Node.js</span>
                    <button class="why-btn" aria-expanded="false">{t.sobreSite.sections.stack.whyBtn}</button>
                  </td>
                </tr>
                <tr class="why-row" hidden>
                  <td colspan="2" class="why-content">
                    <div class="why-inner">Gerencia múltiplas versões do Node.js no servidor sem conflitos com o sistema. Essencial para que o hook de deploy encontre o Node.js correto em uma sessão não-interativa do bash.</div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- ─── 3. Arquitetura ─────────────────────────────────────────── -->
        <section id="arquitetura" class="docs-section fade-in">
          <div class="section-number">03</div>
          <h2>{t.sobreSite.sections.arquitetura.title}</h2>
          <p>{t.sobreSite.sections.arquitetura.desc}</p>

          <!-- Diagrama HTML/CSS da arquitetura -->
          <div class="arch-diagram" aria-label={t.sobreSite.sections.arquitetura.diagramAriaLabel}>
            <div class="arch-node arch-internet">
              <span class="arch-icon">&#127760;</span>
              <div class="arch-info">
                <strong>{t.sobreSite.sections.arquitetura.visitor}</strong>
                <span>HTTPS / porta 443</span>
              </div>
            </div>
            <div class="arch-arrow" aria-hidden="true">&#8595;</div>
            <div class="arch-node">
              <span class="arch-label">Traefik v3.6</span>
              <div class="arch-info">
                <strong>Reverse Proxy + TLS</strong>
                <span>Let's Encrypt automático — portas 80 e 443</span>
              </div>
            </div>
            <div class="arch-arrow" aria-hidden="true">&#8595;</div>
            <div class="arch-node">
              <span class="arch-label">Nginx alpine</span>
              <div class="arch-info">
                <strong>Container Docker</strong>
                <span>proxy_pass para host.docker.internal:4321</span>
              </div>
            </div>
            <div class="arch-arrow" aria-hidden="true">&#8595;</div>
            <div class="arch-node arch-app">
              <span class="arch-label">Astro SSR</span>
              <div class="arch-info">
                <strong>Node.js / PM2 — porta 4321</strong>
                <span>Server-side rendering, rotas de API, autenticação JWT</span>
              </div>
            </div>
            <div class="arch-arrow" aria-hidden="true">&#8595;</div>
            <div class="arch-leaves">
              <div class="arch-node arch-leaf">
                <span class="arch-label">SQLite</span>
                <div class="arch-info">
                  <strong>Banco de dados local</strong>
                  <span>Posts do blog</span>
                </div>
              </div>
              <div class="arch-node arch-leaf">
                <span class="arch-label">Steam API</span>
                <div class="arch-info">
                  <strong>API externa</strong>
                  <span>Dados de jogos em tempo real</span>
                </div>
              </div>
            </div>
          </div>

          <h3>{t.sobreSite.sections.arquitetura.whyTitle}</h3>
          <ul class="docs-list">
            <li>
              <strong>Traefik</strong> — {t.sobreSite.sections.arquitetura.whyTraefik}
            </li>
            <li>
              <strong>Nginx</strong> — {t.sobreSite.sections.arquitetura.whyNginx}
            </li>
            <li>
              <strong>PM2</strong> — {t.sobreSite.sections.arquitetura.whyPm2}
            </li>
            <li>
              <strong>Astro SSR</strong> — {t.sobreSite.sections.arquitetura.whyAstro}
            </li>
          </ul>
        </section>

        <!-- ─── 4. Rodar Localmente ────────────────────────────────────── -->
        <section id="local" class="docs-section fade-in">
          <div class="section-number">04</div>
          <h2>{t.sobreSite.sections.local.title}</h2>

          <p set:html={t.sobreSite.sections.local.prereq} />

          <div class="code-block">
            <div class="code-header">
              <span class="code-lang">bash</span>
              <span class="code-title">{t.sobreSite.sections.local.cloneTitle}</span>
            </div>
            <pre><code><span class="c"># 1. Clonar o repositório</span>
git clone https://github.com/lescuciato/EscuciatoWebSitePersonal.git
cd EscuciatoWebSitePersonal

<span class="c"># 2. Instalar dependências</span>
npm install

<span class="c"># 3. Configurar variáveis de ambiente</span>
cp .env.example .env
<span class="c"># Editar .env com seus valores</span>

<span class="c"># 4. Rodar em desenvolvimento</span>
npm run dev
<span class="c"># Acesse: http://localhost:4321</span></code></pre>
          </div>

          <h3>{t.sobreSite.sections.local.envTitle}</h3>
          <p set:html={t.sobreSite.sections.local.envDesc} />

          <div class="code-block">
            <div class="code-header">
              <span class="code-lang">env</span>
              <span class="code-title">.env</span>
            </div>
            <pre><code>ADMIN_PASSWORD=sua-senha-admin
JWT_SECRET=chave-secreta-jwt-min-32-chars
STEAM_API_KEY=sua-chave-api-steam   <span class="c"># opcional</span>
STEAM_ID=seu-steam-id-64bits        <span class="c"># opcional</span>
HOST=0.0.0.0
PORT=4321</code></pre>
          </div>

          <div class="callout callout-info">
            <span class="callout-icon">&#8505;</span>
            <p set:html={t.sobreSite.sections.local.calloutSteam} />
          </div>
        </section>

        <!-- ─── 5. Deploy ──────────────────────────────────────────────── -->
        <section id="deploy" class="docs-section fade-in">
          <div class="section-number">05</div>
          <h2>{t.sobreSite.sections.deploy.title}</h2>
          <p set:html={t.sobreSite.sections.deploy.desc} />

          <div class="code-block">
            <div class="code-header">
              <span class="code-lang">bash</span>
              <span class="code-title">{t.sobreSite.sections.deploy.flowTitle}</span>
            </div>
            <pre><code><span class="c"># Configurar remote de produção (uma única vez)</span>
git remote add production root@SEU_SERVIDOR:/root/repos/website.git

<span class="c"># Deploy: commitar e enviar</span>
git add .
git commit -m "feat: descrição das mudanças"
git push production main</code></pre>
          </div>

          <h3>{t.sobreSite.sections.deploy.autoTitle}</h3>
          <p set:html={t.sobreSite.sections.deploy.autoDesc} />

          <ol class="docs-steps">
            <li>
              <span class="step-num">1</span>
              <div>
                <strong>{t.sobreSite.sections.deploy.step1Title}</strong>
                <span set:html={t.sobreSite.sections.deploy.step1Desc} />
              </div>
            </li>
            <li>
              <span class="step-num">2</span>
              <div>
                <strong><code class="inline-code">npm ci</code></strong>
                <span set:html={t.sobreSite.sections.deploy.step2Desc} />
              </div>
            </li>
            <li>
              <span class="step-num">3</span>
              <div>
                <strong><code class="inline-code">npm run build</code></strong>
                <span>{t.sobreSite.sections.deploy.step3Desc}</span>
              </div>
            </li>
            <li>
              <span class="step-num">4</span>
