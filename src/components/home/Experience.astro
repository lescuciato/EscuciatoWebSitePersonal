---
/**
 * Experience — timeline of professional roles + education + certifications.
 */

const experience = [
  {
    period: '01/2022 – Present',
    role: 'Sr. Atlassian Consultant',
    company: 'Modus Create',
    current: true,
  },
  {
    period: '06/2021 – 02/2022',
    role: 'Squad Leader',
    company: 'Modus Create',
    current: false,
  },
  {
    period: '10/2019 – 06/2021',
    role: 'Transformation Lead',
    company: 'Zup Innovation',
    current: false,
  },
  {
    period: '09/2018 – 10/2019',
    role: 'Agile Coach & Jira Administrator',
    company: 'Softvaro',
    current: false,
  },
  {
    period: '09/2015 – 08/2018',
    role: 'Scrum Master',
    company: 'CI&T (Europe)',
    current: false,
  },
  {
    period: '05/2008 – 04/2011',
    role: 'Network Support',
    company: 'AT&T',
    current: false,
  },
];

const certifications = [
  {
    code: 'ACP-120',
    name: 'Atlassian Certified Jira Administrator for Cloud',
  },
  {
    code: 'ACP-620',
    name: 'Atlassian Certified in Managing Jira Projects for Cloud',
  },
];
---

<section class="section experience-section">
  <div class="container experience-grid">

    <!-- Experience timeline -->
    <div>
      <h2 class="section-title fade-in">Work <span>Experience</span></h2>
      <div class="timeline">
        {experience.map((item, i) => (
          <div class={`timeline-item fade-in ${item.current ? 'current' : ''}`} style={`transition-delay: ${i * 60}ms`}>
            <div class="timeline-dot" aria-hidden="true"></div>
            <div class="timeline-body">
              <div class="timeline-period">{item.period}</div>
              <div class="timeline-role">{item.role}</div>
              <div class="timeline-company">{item.company}</div>
              {item.current && <span class="timeline-badge">Current</span>}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Right column: Education + Certifications -->
    <div class="right-col">
      <!-- Education -->
      <div class="edu-block fade-in">
        <h2 class="section-title">Education</h2>
        <div class="edu-card card">
          <div class="edu-degree">System Analysis</div>
          <div class="edu-school">Pontifícia Universidade Católica de Campinas</div>
          <div class="edu-period">2007 – 2013</div>
        </div>
      </div>

      <!-- Certifications -->
      <div class="cert-block fade-in">
        <h2 class="section-title">Certifications</h2>
        <div class="cert-list">
          {certifications.map((cert) => (
            <div class="cert-item card">
              <div class="cert-code">{cert.code}</div>
              <div class="cert-name">{cert.name}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .experience-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 900px) {
    .experience-grid {
      grid-template-columns: 1fr 380px;
    }
  }

  /* ─── Timeline ─── */
  .timeline {
    position: relative;
    padding-left: var(--space-3);
    margin-top: var(--space-4);
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(to bottom, var(--color-accent), transparent);
  }

  .timeline-item {
    position: relative;
    padding: var(--space-2) var(--space-2) var(--space-2) var(--space-3);
    margin-bottom: var(--space-2);
    border-radius: var(--radius-md);
    transition: background var(--transition-fast);
  }

  .timeline-item:hover {
    background: rgba(99, 102, 241, 0.05);
  }

  .timeline-dot {
    position: absolute;
    left: -8px;
    top: 18px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-border);
    border: 2px solid var(--color-bg);
    transition: background var(--transition-fast);
  }

  .timeline-item.current .timeline-dot {
    background: var(--color-accent);
    box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.2);
  }

  .timeline-period {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-family: 'JetBrains Mono', monospace;
    margin-bottom: 4px;
  }

  .timeline-role {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 2px;
  }

  .timeline-company {
    font-size: 0.875rem;
    color: var(--color-accent-2);
  }

  .timeline-badge {
    display: inline-block;
    margin-top: 6px;
    padding: 2px 8px;
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.25);
    border-radius: 100px;
    font-size: 0.7rem;
    color: var(--color-success);
    font-weight: 500;
  }

  /* ─── Right column ─── */
  .right-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* ─── Education ─── */
  .edu-block,
  .cert-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .edu-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .edu-degree {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .edu-school {
    font-size: 0.875rem;
    color: var(--color-accent-2);
  }

  .edu-period {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-family: 'JetBrains Mono', monospace;
  }

  /* ─── Certifications ─── */
  .cert-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cert-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cert-code {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    font-family: 'JetBrains Mono', monospace;
  }

  .cert-name {
    font-size: 0.875rem;
    color: var(--color-text);
    line-height: 1.4;
  }
</style>
