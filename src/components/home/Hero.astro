---
/**
 * Hero — above-the-fold introduction section (personal version).
 * Profile photo placeholder at /images/profile.jpg
 */
---

<section class="hero">
  <div class="container hero-inner">
    <!-- Text content -->
    <div class="hero-content fade-in">
      <h1 class="hero-name">Leonardo Escuciato</h1>
      <p class="hero-title">Sr. Atlassian Consultant</p>

      <p class="hero-summary">
        Apaixonado por tecnologia e lifestyle.
        Morador de Campinas, São Paulo, Brasil.
      </p>

      <div class="hero-cta">
        <a href="mailto:lescuciato@gmail.com" class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          Contato
        </a>
        <a
          href="https://www.linkedin.com/in/leonardo-escuciato"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-ghost"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
          LinkedIn
        </a>
        <a href="/profissional" class="btn btn-ghost">
          Ver perfil profissional →
        </a>
      </div>
    </div>

    <!-- Profile photo -->
    <div class="hero-photo fade-in">
      <div class="photo-frame">
        <!--
          PHOTO PLACEHOLDER
          Replace the placeholder below with the actual profile photo.
          File location: /public/images/profile.jpg
          Recommended: square crop, at least 400×400px, .webp format preferred.
        -->
        <img
          src="/images/profile.jpg"
          alt="Leonardo Escuciato"
          width="360"
          height="360"
          class="profile-img"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <!-- Fallback avatar when photo is not yet available -->
        <div class="avatar-fallback" aria-hidden="true">
          <span>LE</span>
        </div>
        <div class="photo-glow" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-12) 0 var(--space-8);
    position: relative;
    overflow: hidden;
  }

  /* Subtle background gradient */
  .hero::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    align-items: center;
    text-align: center;
  }

  @media (min-width: 768px) {
    .hero-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      text-align: left;
    }
  }

  /* ─── Content ─── */
  .hero-content {
    flex: 1;
    max-width: 600px;
  }

  .hero-name {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 8px;
    background: linear-gradient(135deg, var(--color-text) 0%, var(--color-accent-2) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-title {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    color: var(--color-accent-2);
    font-weight: 500;
    margin-bottom: var(--space-3);
  }

  .hero-summary {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-4);
    max-width: 520px;
  }

  @media (max-width: 767px) {
    .hero-summary {
      margin: 0 auto var(--space-4);
    }
  }

  .hero-cta {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hero-cta {
      justify-content: flex-start;
    }
  }

  /* ─── Photo ─── */
  .hero-photo {
    flex-shrink: 0;
  }

  .photo-frame {
    position: relative;
    width: 240px;
    height: 240px;
  }

  @media (min-width: 768px) {
    .photo-frame {
      width: 300px;
      height: 300px;
    }
  }

  .profile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid var(--color-accent);
    position: relative;
    z-index: 1;
  }

  .avatar-fallback {
    display: none;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-2) 100%);
    border: 3px solid var(--color-accent);
    font-size: 3rem;
    font-weight: 700;
    color: white;
    position: relative;
    z-index: 1;
  }

  /* Show fallback by default (photo will hide it if it loads) */
  .profile-img + .avatar-fallback {
    display: flex;
    position: absolute;
    top: 0;
    left: 0;
  }

  /* When image loads successfully, show it over the fallback */
  .profile-img:not([style*="display: none"]) {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
  }

  .photo-glow {
    position: absolute;
    inset: -16px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.2) 0%, transparent 70%);
    border-radius: 50%;
    z-index: 0;
    pointer-events: none;
  }
</style>
